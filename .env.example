# =========================================================
# Court Transcriber — пример переменных окружения
# Скопируй в .env и заполни своими значениями.
# =========================================================

# --- Выбор бэкенда ASR ---
# whisperx | yandex | mock
#   whisperx — локально на GPU (бесплатно, нужен HF_TOKEN)
#   yandex   — Yandex SpeechKit (платно, ~0.5₽/сек, нужны YANDEX_API_KEY/FOLDER_ID)
#   mock     — фейковая расшифровка для тестов UI без GPU и интернета
ASR_BACKEND=whisperx

# --- WhisperX (локально, через GPU) ---
# Модель Whisper. Варианты: tiny / base / small / medium / large-v3
# Для RTX 5070 (12GB VRAM) рекомендуется large-v3 (лучшее качество русского)
WHISPER_MODEL=large-v3
# cuda | cpu — для NVIDIA GPU используй cuda
WHISPER_DEVICE=cuda
# float16 (fast, GPU) | int8 (smaller, CPU) | float32 (most accurate)
WHISPER_COMPUTE_TYPE=float16
# Язык по умолчанию (можно переопределить из API)
WHISPER_LANGUAGE=ru
# HuggingFace token нужен, чтобы скачать pyannote-модели для диаризации.
# Получи на https://huggingface.co/settings/tokens и прими условия
# использования pyannote/speaker-diarization-3.1
HF_TOKEN=

# Модель диаризации pyannote pipeline. Пустая строка = whisperx сам выбирает
# (на 3.8 это community-1). Используется только при DIARIZATION_BACKEND=pyannote.
DIARIZATION_MODEL=

# Диаризационный бэкенд:
#   auto     — NeMo Sortformer если установлен, fallback на pyannote (рекомендуется)
#   nemo     — только NVIDIA NeMo Sortformer (нужен nemo_toolkit — install-nemo.bat)
#   pyannote — только pyannote
# Sortformer — language-agnostic (определяет смену голосов по embeddings, не текст).
# Сильнее на длинных записях и при overlap.
DIARIZATION_BACKEND=auto

# Модель NeMo Sortformer (e2e transformer, до 4 спикеров).
NEMO_DIARIZATION_MODEL=nvidia/diar_sortformer_4spk-v1

# Модель NeMo MSDD (multi-scale diarization decoder, поддерживает много спикеров).
# Варианты:
#   nvidia/diar_msdd_telephonic — телефонный домен, общий
#   nvidia/diar_msdd_meeting    — для митингов с многими спикерами
NEMO_MSDD_MODEL=nvidia/diar_msdd_telephonic

# Препроцессинг аудио перед распознаванием (highpass+lowpass+dynaudnorm+16kHz mono).
# По умолчанию ВЫКЛ — пользователь не хочет потерь от фильтров, особенно на тихих
# голосах. Можно включить если в записях много шума.
AUDIO_PREPROCESS=false
# Агрессивный денойзинг (afftdn). По умолчанию выкл — он может срезать тихую речь.
AUDIO_PREPROCESS_AGGRESSIVE=false
# Максимум секунд паузы для слияния соседних реплик одного спикера.
# 0.8 безопасно — короткие отдельные реплики «Да.»/«Нет.» не сольются.
MERGE_MAX_GAP_SECONDS=0.8

# Если пауза между сегментами длиннее — в результате появится "[пауза N сек]".
# 30 сек — слышимая для мамы пауза, например ожидание ответа свидетеля.
SILENCE_PAUSE_THRESHOLD_SECONDS=30

# --- Yandex SpeechKit (облачный fallback) ---
# IAM-токен или API-ключ. См. https://cloud.yandex.ru/docs/iam/operations/iam-token/create
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- Сервер ---
HOST=0.0.0.0
PORT=8000
# Папка для временных аудиофайлов и готовых .docx
STORAGE_DIR=./storage
# Максимальный размер аудиофайла (байт). 2 GB по умолчанию.
MAX_UPLOAD_BYTES=2147483648

# --- Auth ---
# Базовый логин/пароль для входа в web-интерфейс.
# Сгенерируй сильный пароль (минимум 16 символов).
AUTH_USERNAME=mom
AUTH_PASSWORD_HASH=
# Секрет для JWT-сессий
JWT_SECRET=
JWT_TTL_HOURS=24

# --- Очередь / worker ---
QUEUE_DB_PATH=./storage/queue.sqlite
WORKER_CONCURRENCY=1
